generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  markedLogs    Attendance[]   @relation("AttendanceMarker")
  attendanceLog Attendance[]   @relation("AttendanceUser")
  postedHomeworks Homework[]   @relation("HomeworkCreator")
  postedNews    News[]         @relation("NewsCreator")
  notifications Notification[]
  parent        Parent?
  staff         Staff?
  student       Student?
  teacher       Teacher?
}

model Parent {
  id        Int       @id @default(autoincrement())
  name      String
  contact   String
  userId    Int?      @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [userId], references: [id])
  students  Student[]
}

model Student {
  id                 Int          @id @default(autoincrement())
  name               String
  status             String       @default("ACTIVE")
  profileImage       String?
  className          String?
  howDidYouHear      String?
  enquiryStatus      String?
  dateOfBirth        DateTime?
  age                Int
  city               String?
  state              String?
  residentialAddress String?
  permanentAddress   String?
  fatherName         String?
  fatherEmail        String?
  fatherMobile       String?
  motherName         String?
  motherEmail        String?
  motherMobile       String?
  feeOffered         Float?
  userId             Int?         @unique
  parentId           Int?
  course             String
  batchId            Int?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  attendance         Attendance[]
  fees               Fee[]
  homeworks          Homework[]
  marks              Mark[]
  batch              Batch?       @relation(fields: [batchId], references: [id])
  parent             Parent?      @relation(fields: [parentId], references: [id])
  user               User?        @relation(fields: [userId], references: [id])
}

model Homework {
  id             Int      @id @default(autoincrement())
  subjectName    String
  sectionName    String
  className      String
  homeworkDate   DateTime
  submissionDate DateTime
  description    String
  attachmentFile String?
  studentId      Int
  createdById    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      User     @relation("HomeworkCreator", fields: [createdById], references: [id])
  student        Student  @relation(fields: [studentId], references: [id])

  @@index([studentId, homeworkDate])
}

model News {
  id          Int      @id @default(autoincrement())
  title       String
  summary     String
  content     String
  imageFile   String?
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation("NewsCreator", fields: [createdById], references: [id])

  @@index([createdAt])
}

model Teacher {
  id        Int      @id @default(autoincrement())
  name      String
  subject   String
  userId    Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batches   Batch[]
  user      User?    @relation(fields: [userId], references: [id])
}

model Staff {
  id               Int       @id @default(autoincrement())
  name             String
  status           String    @default("ACTIVE")
  profileImage     String?
  role             String
  dateOfBirth      DateTime?
  email            String?
  contactNumber    String?
  emergencyContact String?
  address          String?
  city             String?
  state            String?
  qualification    String?
  experienceYears  Int?
  joiningDate      DateTime?
  userId           Int?      @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  salary           Float?
  user             User?     @relation(fields: [userId], references: [id])
}

model Attendance {
  id         Int      @id @default(autoincrement())
  userId     Int
  studentId  Int?
  date       DateTime
  status     String
  targetType String
  markedById Int?
  notes      String?
  createdAt  DateTime @default(now())
  markedBy   User?    @relation("AttendanceMarker", fields: [markedById], references: [id])
  student    Student? @relation(fields: [studentId], references: [id])
  user       User     @relation("AttendanceUser", fields: [userId], references: [id])

  @@index([date, targetType])
}

model Mark {
  id        Int      @id @default(autoincrement())
  studentId Int
  subject   String
  marks     Int
  examType  String?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
}

model Fee {
  id            Int       @id @default(autoincrement())
  studentId     Int
  amount        Float
  status        String
  paidOn        DateTime?
  receiptNo     String?
  createdAt     DateTime  @default(now())
  amountPaidFor String?
  dateOfPayment DateTime?
  modeOfPayment String?
  notes         String?
  payeeName     String?
  invoiceFile   String?
  student       Student   @relation(fields: [studentId], references: [id])
}

model Course {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  createdAt DateTime @default(now())
  batches   Batch[]
}

model Batch {
  id        Int       @id @default(autoincrement())
  name      String
  courseId  Int
  teacherId Int?
  timing    String
  createdAt DateTime  @default(now())
  teacher   Teacher?  @relation(fields: [teacherId], references: [id])
  course    Course    @relation(fields: [courseId], references: [id])
  students  Student[]
}

model Enrollment {
  id                 Int       @id @default(autoincrement())
  name               String
  parentName         String?
  email              String
  age                Int
  course             String
  status             String    @default("PENDING")
  notes              String?
  createdAt          DateTime  @default(now())
  reviewedBy         Int?
  city               String?
  className          String?
  dateOfBirth        DateTime?
  enquiryStatus      String?
  fatherEmail        String?
  fatherMobile       String?
  fatherName         String?
  feeOffered         Float?
  howDidYouHear      String?
  motherEmail        String?
  motherMobile       String?
  motherName         String?
  permanentAddress   String?
  residentialAddress String?
  state              String?
}

model Event {
  id            Int      @id @default(autoincrement())
  name          String
  date          DateTime
  description   String
  registrations Int      @default(0)
  createdAt     DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  status    String   @default("INFO")
  type      String   @default("GENERAL")
  monthKey  String?
  resolvedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
